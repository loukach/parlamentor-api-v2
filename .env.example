# Parlamentor v2 environment variables

# App database (read-write)
# On Render: auto-injected as postgres:// -- the app rewrites to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://parlamentor_user:PASSWORD@HOST:5432/parlamentor

# Parla! database (read-only, parliamentary data)
# Render external URL format: postgresql+asyncpg://USER:PASS@dpg-XXX.frankfurt-postgres.render.com/viriato
PARLA_DATABASE_URL=postgresql+asyncpg://viriato_user:PASSWORD@HOST:5432/viriato

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:5180,https://parlamentor-web.onrender.com
